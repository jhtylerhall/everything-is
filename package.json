{
  "name": "cream-cheese-platformer-expo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas:login": "npx eas-cli login",
    "eas:init": "npx eas-cli init",
    "eas:build:ios": "npx eas-cli build --platform ios --profile production",
    "eas:build:android": "npx eas-cli build --platform android --profile production",
    "eas:build:all": "npx eas-cli build --platform all --profile production",
    "eas:update": "npx eas-cli update --branch production --message \"prod update\""
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-gl": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-three": "^8.0.0",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "three": "^0.166.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/three": "^0.183.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
